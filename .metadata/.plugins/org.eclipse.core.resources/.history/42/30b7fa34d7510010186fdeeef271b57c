			private static void findMissingNumber() {
		//9. Find the Missing Number in an Array
		//Question: You are given an array of numbers from 1 to N with one number missing. Find the missing number.
		//Input: [1, 2, 4, 5, 6]
		//Output: 3
				List<Integer> list = Arrays.asList(1, 2, 4, 5, 6);// 21
				int n = list.size() + 1;
				int sum = (n * (n + 1)) / 2;
				int actualSum = 0;
				for (Integer num : list) {
					actualSum += num;
				}

				System.out.println("Missing number : " + (sum - actualSum));
			}

