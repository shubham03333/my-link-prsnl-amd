			private static void mostFrequentCharacter() {
		//17. Find the Most Frequent Character in a String
		//Question: Write a Java program that finds the most frequent character in a string.
		//Input: "aaabbbbcc"
		//Output: "b"
				String str = "aaabbbbccd";

