			private static void capitalizeFirstLetterOfEachWord() {
		//1. Capitalize the First Letter of Each Word in a Sentence
		//Question: Write a Java program that capitalizes the first letter of each word in a given sentence. The sentence
		//will consist of multiple words separated by spaces. You should preserve the case of the other letters in each word.
		//Input: "hello world from java"
		//Output: "Hello World From Java"

				String str = "hello world from java";

				String s = Arrays.stream(str.split("\\s+")).map(w -> {
					return w.substring(0, 1).toUpperCase() + w.substring(1, w.length());
				}).collect(Collectors.joining(" "));

				System.out.println(s);
			}

			private static void capitalizeFirstLetterOfFirstAndLastName() {
				List<String> nameList = Arrays.asList("james bond", "alex jordan", "john smith");
				nameList.stream().map(w -> {
					String[] name = w.split("\\s+");
					String firstName = name[0];
					String lastName = name[1];
					String fullName = firstName.substring(0, 1).toUpperCase() + firstName.substring(1, firstName.length()) + " "
							+ lastName.substring(0, 1).toUpperCase() + lastName.substring(1, lastName.length());

					return fullName;

				}).forEach(w -> System.out.println(w));
				;
			}

			private static void capitalizeFirstLetterOfLastName() {
		//Question: Write a Java program that capitalizes the first letter of second word in a given name.
		//The name will consist of multiple words separated by spaces.
		//You should preserve the case of the other letters in each word.

				List<String> nameList = Arrays.asList("james bond", "alex jordan", "john smith");
				nameList.stream().map(w -> {

					String[] name = w.split("\\s+");
					String firstName = name[0];

					String lastName = name[1];
					String fullName = firstName + " " + lastName.substring(0, 1).toUpperCase()
							+ lastName.substring(1, lastName.length());

					return fullName;
				}).forEach(w -> System.out.println(w));
			}



