			private static void longestSubstringAtMostTwoDistinctCharacter() {
		//1. Find the Longest Substring with At Most Two Distinct Characters
		//Question: Write a Java program to find the length of the longest substring with at most two distinct characters.
		//Input: "eceba"
		//Output: 3 (substring is "ece")

				String s = "ecebalp";
				Set<Character> subStr = new LinkedHashSet<>();
				String str = "";
				String maxStr = "";
				for (int i = 0; i < s.length(); i++) {
					if (!subStr.add(s.charAt(i))) {
						str += s.charAt(i);
						if (maxStr.length() < str.length()) {
							maxStr = str;
						}
						str = "";
						subStr.clear();
					} else {
						str += s.charAt(i);
					}

				}
				System.out.println("Longest Substring with At Most Two Distinct Characters :: " + maxStr);
			}

			private static void longestNonRepeatingCharacters() {
		//20. Find the Longest Substring Without Repeating Characters
		//Question: Write a Java program to find the length of the longest substring without repeating characters.
		//Input: "abcabcbb"
		//Output: 3 (substring is "abc")
				String s = "abcabcbb";
				Set<Character> nonRepeatedSet = new HashSet<>();
				int maxSubstring = 0;
				for (int i = 0; i < s.length(); i++) {
					if (!nonRepeatedSet.add(s.charAt(i))) {
						if (maxSubstring < nonRepeatedSet.size())
							maxSubstring = nonRepeatedSet.size();

						nonRepeatedSet.clear();

					}
				}

				System.out.println("Longest Substring Without Repeating Characters : " + maxSubstring);
			}

